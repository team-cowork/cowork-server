# ── Spring 프로파일 ─────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local

# ── MySQL ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=
MYSQL_USER=cowork
MYSQL_PASSWORD=

# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=root
POSTGRES_PASSWORD=

# ── MongoDB ────────────────────────────────────────────────────────────────
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_ACCESS_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=2592000000

# ── OAuth2 ─────────────────────────────────────────────────────────────────
OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=
OAUTH2_GITHUB_CLIENT_ID=
OAUTH2_GITHUB_CLIENT_SECRET=

# ── MinIO (로컬 S3 대체) ────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── AWS S3 / MinIO ─────────────────────────────────────────────────────────
# 로컬: minioadmin / minioadmin (MinIO 기본값과 맞춤)
# 프로덕션: 실제 IAM 자격증명 입력
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
S3_BUCKET=cowork-bucket
S3_BASE_URL=http://localhost:9000/cowork-bucket

# ── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin

# ── LiveKit ──────────────────────────────────────────────────────────────────
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
