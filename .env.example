# ── Spring 프로파일 ─────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local

# ── MySQL ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=
MYSQL_USER=cowork
MYSQL_PASSWORD=

# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=root
POSTGRES_PASSWORD=

# ── MongoDB ────────────────────────────────────────────────────────────────
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_ACCESS_EXPIRE=30m
JWT_REFRESH_EXPIRE=2160h

# ── OAuth2 ─────────────────────────────────────────────────────────────────
OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=
OAUTH2_GITHUB_CLIENT_ID=
OAUTH2_GITHUB_CLIENT_SECRET=

# ── DataGSM OAuth2 ───────────────
DATAGSM_CLIENT_ID=
DATAGSM_TOKEN_URL=https://oauth.authorization.datagsm.kr/v1/oauth/token
DATAGSM_USERINFO_URL=https://oauth.resource.datagsm.kr/userinfo

# ── MinIO (로컬 S3 대체) ────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── MinIO (S3 호환, production도 MinIO 사용) ────────────────────────────────
# 이 값들이 "클라이언트(앱)가 접근 가능한 주소"여야 함.
MINIO_REGION=ap-northeast-2
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cowork-bucket
# 서버(백엔드) 내부에서 MinIO로 붙는 주소 (내부 IP/내부 DNS 가능)
MINIO_INTERNAL_ENDPOINT=http://localhost:9000
# 클라이언트(앱/외부)가 접근 가능한 주소 (외부 도메인/URL)
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
# 팀 아이콘 등 "공개 URL"로 내려줄 base URL (클라이언트 접근 주소)
MINIO_PUBLIC_BASE_URL=http://localhost:9000/cowork-bucket
MINIO_PATH_STYLE_ACCESS_ENABLED=true

# ── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin

# ── LiveKit ──────────────────────────────────────────────────────────────────
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
