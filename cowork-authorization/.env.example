# Server
PORT=8081

# Database
DB_DSN=user:password@tcp(cowork-mysql:3306)/cowork_authorization?charset=utf8mb4&parseTime=True&loc=Local

# DataGSM OAuth2
DATAGSM_CLIENT_ID=your_client_id
DATAGSM_TOKEN_URL=https://oauth.authorization.datagsm.kr/v1/oauth/token
DATAGSM_USERINFO_URL=https://oauth.resource.datagsm.kr/userinfo

# JWT (HS256, cowork-gateway와 동일한 값 사용)
JWT_SECRET=your_jwt_secret_shared_with_gateway
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=168h

# Eureka
EUREKA_SERVER_URL=http://cowork-config:8761/eureka
EUREKA_APP_NAME=cowork-authorization
EUREKA_INSTANCE_HOST=cowork-authorization
EUREKA_INSTANCE_PORT=8081

# User Service
USER_SERVICE_URL=http://cowork-user:8080
