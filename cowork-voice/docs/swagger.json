{
    "swagger": "2.0",
    "info": {
        "description": "음성 채널 서비스 — LiveKit 기반 음성 통화 세션 관리",
        "title": "Cowork Voice API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/api",
    "paths": {
        "/voice/channels/{channel_id}/join": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "채널에 입장합니다. LiveKit 토큰과 연결 URL을 반환합니다. 기존 세션이 없으면 새로 생성됩니다.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "voice"
                ],
                "summary": "음성 채널 입장",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "채널 ID",
                        "name": "channel_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/github_com_cowork_cowork-voice_internal_dto.JoinResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/github_com_cowork_cowork-voice_internal_apperror.AppError"
                        }
                    },
                    "403": {
                        "description": "채널 멤버가 아님",
                        "schema": {
                            "$ref": "#/definitions/github_com_cowork_cowork-voice_internal_apperror.AppError"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/github_com_cowork_cowork-voice_internal_apperror.AppError"
                        }
                    }
                }
            }
        },
        "/voice/channels/{channel_id}/leave": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "채널에서 퇴장합니다. 마지막 참여자가 나가면 방이 자동으로 삭제됩니다.",
                "tags": [
                    "voice"
                ],
                "summary": "음성 채널 퇴장",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "채널 ID",
                        "name": "channel_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "퇴장 성공"
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/github_com_cowork_cowork-voice_internal_apperror.AppError"
                        }
                    },
                    "404": {
                        "description": "활성 세션 없음",
                        "schema": {
                            "$ref": "#/definitions/github_com_cowork_cowork-voice_internal_apperror.AppError"
                        }
                    }
                }
            }
        },
        "/voice/channels/{channel_id}/participants": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "현재 음성 채널에 참여 중인 사용자 목록을 반환합니다.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "voice"
                ],
                "summary": "채널 참여자 목록 조회",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "채널 ID",
                        "name": "channel_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/github_com_cowork_cowork-voice_internal_dto.ParticipantsResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/github_com_cowork_cowork-voice_internal_apperror.AppError"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/github_com_cowork_cowork-voice_internal_apperror.AppError"
                        }
                    }
                }
            }
        },
        "/voice/sessions/{session_id}": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "session_id로 음성 세션 정보를 조회합니다.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "voice"
                ],
                "summary": "세션 조회",
                "parameters": [
                    {
                        "type": "string",
                        "description": "세션 ID",
                        "name": "session_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/github_com_cowork_cowork-voice_internal_dto.SessionResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/github_com_cowork_cowork-voice_internal_apperror.AppError"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/github_com_cowork_cowork-voice_internal_apperror.AppError"
                        }
                    }
                }
            }
        },
        "/voice/webhook": {
            "post": {
                "description": "LiveKit 서버가 전송하는 participant_joined / participant_left / room_finished 이벤트를 처리합니다. LiveKit 서버 내부 호출용이며 직접 호출하지 않습니다.",
                "consumes": [
                    "application/json"
                ],
                "tags": [
                    "webhook"
                ],
                "summary": "LiveKit 웹훅 수신",
                "parameters": [
                    {
                        "type": "string",
                        "description": "LiveKit 웹훅 서명",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                }
            }
        }
    },
    "definitions": {
        "github_com_cowork_cowork-voice_internal_apperror.AppError": {
            "description": "API 에러 응답",
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer",
                    "example": 404
                },
                "message": {
                    "type": "string",
                    "example": "session not found"
                },
                "status": {
                    "type": "string",
                    "example": "NOT_FOUND"
                }
            }
        },
        "github_com_cowork_cowork-voice_internal_dto.JoinResponse": {
            "type": "object",
            "properties": {
                "livekit_url": {
                    "type": "string"
                },
                "room_name": {
                    "type": "string"
                },
                "session_id": {
                    "type": "string"
                },
                "token": {
                    "type": "string"
                }
            }
        },
        "github_com_cowork_cowork-voice_internal_dto.ParticipantInfo": {
            "type": "object",
            "properties": {
                "joined_at": {
                    "type": "string"
                },
                "user_id": {
                    "type": "integer"
                }
            }
        },
        "github_com_cowork_cowork-voice_internal_dto.ParticipantsResponse": {
            "type": "object",
            "properties": {
                "channel_id": {
                    "type": "integer"
                },
                "participants": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/github_com_cowork_cowork-voice_internal_dto.ParticipantInfo"
                    }
                },
                "room_name": {
                    "type": "string"
                }
            }
        },
        "github_com_cowork_cowork-voice_internal_dto.SessionResponse": {
            "type": "object",
            "properties": {
                "channel_id": {
                    "type": "integer"
                },
                "ended_at": {
                    "type": "string"
                },
                "session_id": {
                    "type": "string"
                },
                "started_at": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                },
                "team_id": {
                    "type": "integer"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "\"Bearer {access_token}\" 형식으로 입력하세요.",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}