{
  "title": "Cowork Spring Boot 서비스",
  "uid": "cowork-spring-boot",
  "tags": ["cowork", "spring-boot"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP 요청 Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{application=\"$service\"}[1m]))",
          "legendFormat": "{{uri}}",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP 응답 시간 P99 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, uri) (rate(http_server_requests_seconds_bucket{application=\"$service\"}[5m]))) * 1000",
          "legendFormat": "P99 {{uri}}",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{application=\"$service\"}[5m]))) * 1000",
          "legendFormat": "P95 {{uri}}",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 3,
      "title": "HTTP 5xx 에러율 (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$service\", status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"$service\"}[1m])) * 100",
          "legendFormat": "5xx 에러율",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 4,
      "title": "JVM 힙 메모리 (used / max)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"$service\", area=\"heap\"}",
          "legendFormat": "Used {{id}}",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"$service\", area=\"heap\"}",
          "legendFormat": "Max {{id}}",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 5,
      "title": "JVM GC Pause (ms/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"$service\"}[1m]) * 1000",
          "legendFormat": "{{action}} {{cause}}",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 6,
      "title": "JVM 스레드",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"$service\"}",
          "legendFormat": "Live",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"$service\"}",
          "legendFormat": "Daemon",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    },
    {
      "id": 7,
      "title": "DB 커넥션 풀 (HikariCP)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"$service\"}",
          "legendFormat": "Active",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "hikaricp_connections_idle{application=\"$service\"}",
          "legendFormat": "Idle",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "hikaricp_connections_max{application=\"$service\"}",
          "legendFormat": "Max",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    },
    {
      "id": 8,
      "title": "Kafka 프로듀서 레이트",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "rate(kafka_producer_record_send_total{application=\"$service\"}[1m])",
          "legendFormat": "Sent/s",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "label": "Datasource"
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(http_server_requests_seconds_count{job=~\"cowork-.*\"}, application)",
        "refresh": 2,
        "label": "Service",
        "hide": 0
      }
    ]
  }
}
