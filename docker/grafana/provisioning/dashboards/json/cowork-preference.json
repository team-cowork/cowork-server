{
  "title": "cowork-preference",
  "uid": "cowork-preference",
  "tags": ["cowork", "service", "preference"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "서비스 상태",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{job=\"cowork-preference\"}",
          "legendFormat": "preference",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP 요청 Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(vertx_http_server_requests_total{job=\"cowork-preference\"}[1m])",
          "legendFormat": "{{method}} {{route}}",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP 응답 시간 P99 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(vertx_http_server_response_time_seconds_bucket{job=\"cowork-preference\"}[5m])) * 1000",
          "legendFormat": "P99",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "label": "Datasource"
      }
    ]
  }
}
