{
  "title": "Cowork Chat & Preference 서비스",
  "uid": "cowork-chat-preference",
  "tags": ["cowork", "nodejs", "vertx"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Chat - Node.js 이벤트 루프 지연 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds{job=\"cowork-chat\"} * 1000",
          "legendFormat": "EventLoop Lag",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 2,
      "title": "Chat - 힙 메모리 사용량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"cowork-chat\"}",
          "legendFormat": "Heap Used",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "nodejs_heap_size_total_bytes{job=\"cowork-chat\"}",
          "legendFormat": "Heap Total",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 3,
      "title": "Chat - 활성 Socket.io 연결 수",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "nodejs_active_handles_total{job=\"cowork-chat\"}",
          "legendFormat": "Active Handles",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "title": "Chat - GC 일시정지 (ms/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(nodejs_gc_duration_seconds_sum{job=\"cowork-chat\"}[1m]) * 1000",
          "legendFormat": "GC {{kind}}",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 5,
      "title": "Preference (Vert.x) - HTTP 요청 Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(vertx_http_server_requests_total{job=\"cowork-preference\"}[1m])",
          "legendFormat": "{{method}} {{route}}",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    },
    {
      "id": 6,
      "title": "Preference (Vert.x) - HTTP 응답 시간 P99 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(vertx_http_server_response_time_seconds_bucket{job=\"cowork-preference\"}[5m])) * 1000",
          "legendFormat": "P99",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "label": "Datasource"
      }
    ]
  }
}
