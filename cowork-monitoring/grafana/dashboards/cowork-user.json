{
  "title": "cowork-user",
  "uid": "cowork-user",
  "tags": ["cowork", "service", "user"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "서비스 상태",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{service=\"user\"}",
          "legendFormat": "user",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP 요청 Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{application=\"cowork-user\"}[1m]))",
          "legendFormat": "{{uri}}",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP 누적 응답 시간 합계 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_sum{application=\"cowork-user\"}[5m]))",
          "legendFormat": "{{uri}}",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "title": "HTTP 5xx 에러율 (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"cowork-user\", status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"cowork-user\"}[1m])) * 100",
          "legendFormat": "5xx 에러율",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 5,
      "title": "BEAM 메모리",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "beam_memory_used_bytes{application=\"cowork-user\"}",
          "legendFormat": "Total",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 6,
      "title": "BEAM Run Queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "beam_run_queue{application=\"cowork-user\"}",
          "legendFormat": "Run Queue",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7,
      "title": "BEAM 프로세스 수",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "beam_process_count{application=\"cowork-user\"}",
          "legendFormat": "Processes",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "label": "Datasource"
      }
    ]
  }
}
