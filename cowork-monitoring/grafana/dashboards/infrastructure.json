{
  "title": "cowork 인프라 (MySQL + Redis + Kafka + PostgreSQL)",
  "uid": "cowork-infrastructure",
  "tags": ["cowork", "infrastructure"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "MySQL - 초당 쿼리 수 (QPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(mysql_global_status_queries{job=\"mysql\"}[1m])",
          "legendFormat": "QPS",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    },
    {
      "id": 2,
      "title": "MySQL - 활성 커넥션",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "mysql_global_status_threads_connected{job=\"mysql\"}",
          "legendFormat": "Connected",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "mysql_global_status_threads_running{job=\"mysql\"}",
          "legendFormat": "Running",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    },
    {
      "id": 3,
      "title": "Redis - 히트율 (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total{job=\"redis\"}[1m]) / (rate(redis_keyspace_hits_total{job=\"redis\"}[1m]) + rate(redis_keyspace_misses_total{job=\"redis\"}[1m])) * 100",
          "legendFormat": "Hit Rate",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 4,
      "title": "Redis - 메모리 사용량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"redis\"}",
          "legendFormat": "Used",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "redis_memory_max_bytes{job=\"redis\"}",
          "legendFormat": "Max",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 5,
      "title": "Kafka - Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (consumergroup, topic) (kafka_consumergroup_lag{job=\"kafka\"})",
          "legendFormat": "{{consumergroup}} / {{topic}}",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    },
    {
      "id": 6,
      "title": "Kafka - 초당 메시지 수",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (topic) (rate(kafka_topic_partition_current_offset{job=\"kafka\"}[1m]))",
          "legendFormat": "{{topic}}",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    },
    {
      "id": 7,
      "title": "PostgreSQL - 활성 커넥션",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"postgres\", state=\"active\"}",
          "legendFormat": "Active",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "pg_stat_activity_count{job=\"postgres\", state=\"idle\"}",
          "legendFormat": "Idle",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    },
    {
      "id": 8,
      "title": "PostgreSQL - 초당 트랜잭션",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{job=\"postgres\", datname=\"cowork_preference\"}[1m])",
          "legendFormat": "Commits/s",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{job=\"postgres\", datname=\"cowork_preference\"}[1m])",
          "legendFormat": "Rollbacks/s",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "label": "Datasource"
      }
    ]
  }
}
