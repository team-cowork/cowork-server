{
  "title": "cowork-chat",
  "uid": "cowork-chat",
  "tags": ["cowork", "service", "chat"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "서비스 상태",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{job=\"cowork-chat\"}",
          "legendFormat": "chat",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Node.js 이벤트 루프 지연 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds{job=\"cowork-chat\"} * 1000",
          "legendFormat": "EventLoop Lag",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 3,
      "title": "Node.js 힙 메모리 사용량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"cowork-chat\"}",
          "legendFormat": "Heap Used",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "nodejs_heap_size_total_bytes{job=\"cowork-chat\"}",
          "legendFormat": "Heap Total",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 4,
      "title": "Node.js 활성 핸들 수",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "nodejs_active_handles_total{job=\"cowork-chat\"}",
          "legendFormat": "Active Handles",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "title": "GC 일시정지 (ms/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(nodejs_gc_duration_seconds_sum{job=\"cowork-chat\"}[1m]) * 1000",
          "legendFormat": "GC {{kind}}",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "label": "Datasource"
      }
    ]
  }
}
