{
    "swagger": "2.0",
    "info": {
        "description": "FCM 디바이스 토큰 관리 및 푸시 알림 서비스",
        "title": "cowork-notification API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/health": {
            "get": {
                "description": "서비스 생존 여부 확인",
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "system"
                ],
                "summary": "헬스 체크",
                "responses": {
                    "200": {
                        "description": "ok",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/notifications/stream": {
            "get": {
                "description": "인증된 사용자의 실시간 알림 이벤트를 Server-Sent Events(SSE)로 스트리밍합니다. 30초마다 keepalive ping을 전송합니다.",
                "produces": [
                    "text/event-stream"
                ],
                "tags": [
                    "notifications"
                ],
                "summary": "SSE 알림 스트림 구독",
                "parameters": [
                    {
                        "type": "integer",
                        "format": "int64",
                        "description": "사용자 ID (Gateway 주입)",
                        "name": "X-User-Id",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "data: {type, title, body, channelId, teamId}",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "401": {
                        "description": "인증 실패",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "SSE not supported",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/notifications/tokens": {
            "post": {
                "description": "사용자의 디바이스 FCM 토큰을 등록합니다",
                "consumes": [
                    "application/json"
                ],
                "tags": [
                    "tokens"
                ],
                "summary": "FCM 토큰 등록",
                "parameters": [
                    {
                        "type": "integer",
                        "format": "int64",
                        "description": "사용자 ID (Gateway 주입)",
                        "name": "X-User-Id",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "토큰 등록 요청",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/token.registerTokenRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created"
                    },
                    "400": {
                        "description": "잘못된 요청",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "401": {
                        "description": "인증 실패",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "내부 서버 오류",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/notifications/tokens/{token}": {
            "delete": {
                "description": "사용자의 디바이스 FCM 토큰을 삭제합니다",
                "tags": [
                    "tokens"
                ],
                "summary": "FCM 토큰 삭제",
                "parameters": [
                    {
                        "type": "integer",
                        "format": "int64",
                        "description": "사용자 ID (Gateway 주입)",
                        "name": "X-User-Id",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "FCM 토큰",
                        "name": "token",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    },
                    "400": {
                        "description": "잘못된 요청",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "401": {
                        "description": "인증 실패",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "토큰 없음",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "내부 서버 오류",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "token.registerTokenRequest": {
            "type": "object",
            "properties": {
                "platform": {
                    "type": "string"
                },
                "token": {
                    "type": "string"
                }
            }
        }
    }
}